# Backend
DATABASE_URL=postgresql+asyncpg://user:password@host/neondb?sslmode=require
DATABASE_URL_RAW=postgresql://user:password@host/neondb?sslmode=require
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
JWT_SECRET=replace-with-64-plus-random-characters-example-8f3a5c7e9d1b2a4f
JWT_LIFETIME_SECONDS=3600
CORS_ORIGINS=http://localhost:5173
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
PASSWORD_MIN_LENGTH=8
SESSION_LIST_DEFAULT_LIMIT=20
SESSION_LIST_MAX_LIMIT=100
MESSAGE_LIST_DEFAULT_LIMIT=50
MESSAGE_LIST_MAX_LIMIT=200
SAVED_ITEM_LIST_DEFAULT_LIMIT=50
SAVED_ITEM_LIST_MAX_LIMIT=200

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8000